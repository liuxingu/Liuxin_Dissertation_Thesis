@ARTICLE{Park2023-fb,
  title     = "Dipole ladders with large Hubbard interaction in a moiré exciton
               lattice",
  author    = "Park, Heonjoon and Zhu, Jiayi and Wang, Xi and Wang, Yingqi and
               Holtzmann, William and Taniguchi, Takashi and Watanabe, Kenji and

@PHDTHESIS{Catalano2017-yj,
  title     = "Spontaneous parametric down-conversion and quantum entanglement",
  author    = "Catalano, Jesse",
  publisher = "Portland State University Library",
  abstract  = "Quantum entanglement has been a topic of much research in modern

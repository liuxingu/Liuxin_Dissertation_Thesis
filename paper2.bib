}

@ARTICLE{Zhang2023-fq,
  title     = "Visualizing moiré ferroelectricity via plasmons and
               nano-photocurrent in graphene/twisted-{WSe2} structures",
  author    = "Zhang, Shuai and Liu, Yang and Sun, Zhiyuan and Chen, Xinzhong
               and Li, Baichang and Moore, S L and Liu, Song and Wang, Zhiying
               and Rossi, S E and Jing, Ran and Fonseca, Jordan and Yang, Birui

  month     =  mar,
  year      =  2019,
  language  = "en"
}

@ARTICLE{Jin2019-ce,
  title     = "Observation of moiré excitons in {WSe2}/{WS2} heterostructure
               superlattices",
  author    = "Jin, Chenhao and Regan, Emma C and Yan, Aiming and Iqbal Bakti

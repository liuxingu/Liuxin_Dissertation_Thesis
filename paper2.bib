@ARTICLE{Robert2018-if,
  title     = "Optical spectroscopy of excited exciton states in {MoS}$_{2}$
               monolayers in van der Waals heterostructures",
  author    = "Robert, C and Semina, M A and Cadiz, F and Manca, M and Courtade,

  month     =  mar,
  year      =  2019,
  language  = "en"
}

@ARTICLE{Liu2019-vj,
  title     = "Van der Waals integration before and beyond two-dimensional
               materials",
  author    = "Liu, Yuan and Huang, Yu and Duan, Xiangfeng",
  journal   = "Nature",
  publisher = "Springer Science and Business Media LLC",
  volume    =  567,
  number    =  7748,
  pages     = "323--333",
  abstract  = "Material integration strategies, such as epitaxial growth,
               usually involve strong chemical bonds and are typically limited
               to materials with strict structure matching and processing
               compatibility. Van der Waals integration, in which pre-fabricated
